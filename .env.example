# Used by: Orchestrator (run-all) and Fetcher (fetch)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Used by: Extractor (extract)
OPENAI_API_KEY=your_openai_key_here

# Model overrides (orchestrator and fetcher only — extractor is hardcoded to gpt-4o-mini)
ORCHESTRATOR_MODEL=claude-sonnet-4-6
FETCHER_MODEL=claude-haiku-4-5-20251001
